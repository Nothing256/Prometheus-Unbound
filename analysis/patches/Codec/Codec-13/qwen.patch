+package org.apache.commons.codec.binary;
+
+/**
+ * This class provides utility methods for working with CharSequence objects.
+ * This implementation is designed to provide the functionality expected by
+ * other Apache Commons Codec components.
+ * 
+ * Based on Apache Commons Lang CharSequenceUtils but adapted for Codec.
+ */
+public class CharSequenceUtils {
+
+    /**
+     * Returns a new CharSequence that is a subsequence of this sequence.
+     */
+    public static CharSequence subSequence(CharSequence cs, int beginIndex, int endIndex) {
+        if (cs == null) {
+            return null;
+        }
+        return cs.subSequence(beginIndex, endIndex);
+    }
+
+    /**
+     * Performs a region matches on two CharSequences with optional case sensitivity.
+     * This is the main method that may have had bugs in the original implementation.
+     */
+    static boolean regionMatches(CharSequence cs1, boolean ignoreCase, int offset1, CharSequence cs2, int offset2, int length) {
+        // Handle nulls
+        if (cs1 == null || cs2 == null) {
+            return cs1 == cs2;
+        }
+
+        // Bounds checks - critical bug fix
+        if (offset1 < 0 || offset2 < 0) {
+            return false;
+        }
+        if (offset1 > cs1.length() || offset2 > cs2.length()) {
+            return false;
+        }
+        if (length < 0) {
+            return false;
+        }
+        if (offset1 + length > cs1.length() || offset2 + length > cs2.length()) {
+            return false;
+        }
+
+        // Character comparison loop - the critical part for locale issues
+        for (int i = 0; i < length; i++) {
+            char c1 = cs1.charAt(offset1 + i);
+            char c2 = cs2.charAt(offset2 + i);
+            
+            if (c1 == c2) {
+                continue; // Same character, continue
+            }
+            
+            if (!ignoreCase) {
+                return false; // Different characters, case sensitive comparison
+            }
+            
+            // Case insensitive comparison
+            // FIX: Avoid locale-sensitive transformations like Character.toLowerCase/UpperCase
+            // Use ASCII-specific conversion
+            if (c1 != c2) {
+                // Check if they are the same letter in different cases
+                if (isAsciiAlpha(c1) && isAsciiAlpha(c2)) {
+                    // Only compare ASCII letters ignoring case
+                    if (toLowerCaseAscii(c1) != toLowerCaseAscii(c2)) {
+                        return false;
+                    }
+                } else {
+                    return false; // Non-ASCII or mixed case
+                }
+            }
+        }
+        
+        return true;
+    }
+    
+    /**
+     * Performs a case sensitive region matches on two CharSequences.
+     */
+    static boolean regionMatches(CharSequence cs1, int offset1, CharSequence cs2, int offset2, int length) {
+        return regionMatches(cs1, false, offset1, cs2, offset2, length);
+    }
+
+    /**
+     * Check if a CharSequence starts with a specified prefix.
+     */
+    public static boolean startsWith(CharSequence str, CharSequence prefix) {
+        if (str == null || prefix == null) {
+            return str == prefix;
+        }
+        if (prefix.length() > str.length()) {
+            return false;
+        }
+        return regionMatches(str, 0, prefix, 0, prefix.length());
+    }
+    
+    /**
+     * Check if a character is an ASCII letter (a-z, A-Z).
+     */
+    private static boolean isAsciiAlpha(char c) {
+        return (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z');
+    }
+    
+    /**
+     * Convert an ASCII letter to lowercase.
+     */
+    private static char toLowerCaseAscii(char c) {
+        if (c >= 'A' && c <= 'Z') {
+            return (char)(c - 'A' + 'a');
+        }
+        return c; // Already lowercase or not a letter
+    }
+}