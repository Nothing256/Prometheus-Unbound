@@ -869,6 +869,13 @@ public class Complex implements Serializable  {
      * @since 1.2
      */
     protected Complex createComplex(double real, double imaginary) {
+        // Normalize signed zeros: treat -0.0 as 0.0 for consistency
+        if (real == 0.0) {
+            real = 0.0;
+        }
+        if (imaginary == 0.0) {
+            imaginary = 0.0;
+        }
         return new Complex(real, imaginary);
     }
 }
