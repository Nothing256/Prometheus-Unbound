      * @return The file input stream represented by <code>str</code>.
      * @throws ParseException if the file is not exist or not readable
      */
+    public static FileInputStream createFileInputStream(final String str) throws ParseException
+    {
+        final File file = new File(str);
+
+        if (!file.exists()) {
+            return null;
+        }
+
+        if (!file.canRead()) {
+            throw new ParseException("File is not readable: " + str);
+        }
+
+        try {
+            return new FileInputStream(file);
+        } catch (final FileNotFoundException e) {
+            // Should not happen since we checked file existence and readability
+            throw new ParseException("Could not create FileInputStream: " + str);
+        }
+    }
 
