+  private static int getIndexSafe(TypeVariable<?>[] types, TypeVariable<?> type) {
+    for (int i = 0; i < types.length; ++i) {
+      if (type.equals(types[i])) {
+        return i;
+      }
+    }
+    return -1; // Not found
+  }
+
+  private static Type resolveTypeVariableFromSuperclass(TypeVariable<?> typeVariable, Class<?> clazz) {
+    // Walk up the class hierarchy to find where this type variable is defined and its mapping
+    Class<?> currentClass = clazz;
+
+    while (currentClass != null && currentClass != Object.class) {
+      Type genericSuperclass = currentClass.getGenericSuperclass();
+      if (genericSuperclass instanceof ParameterizedType) {
+        ParameterizedType paramSuperType = (ParameterizedType) genericSuperclass;
+        Class<?> superClass = (Class<?>) paramSuperType.getRawType();
+
+        // Check if the type variable is declared by this superclass
+        if (superClass.equals(typeVariable.getGenericDeclaration())) {
+          TypeVariable<?>[] superClassTypeVars = superClass.getTypeParameters();
+          int indexInSuper = getIndexSafe(superClassTypeVars, typeVariable);
+
+          if (indexInSuper != -1) {
+            Type[] superClassActualTypes = paramSuperType.getActualTypeArguments();
+            if (indexInSuper < superClassActualTypes.length) {
+              return superClassActualTypes[indexInSuper];
+            }
+          }
+        }
+      }
+
+      // Move to the superclass to continue search
+      currentClass = currentClass.getSuperclass();
+    }
+
+    // Also check interfaces
+    currentClass = clazz;
+    while (currentClass != null && currentClass != Object.class) {
+      Type[] genericInterfaces = currentClass.getGenericInterfaces();
+
+      for (Type genericInterface : genericInterfaces) {
+        if (genericInterface instanceof ParameterizedType) {
+          ParameterizedType paramInterfaceType = (ParameterizedType) genericInterface;
+          Class<?> interfaceClass = (Class<?>) paramInterfaceType.getRawType();
+
+          if (interfaceClass.equals(typeVariable.getGenericDeclaration())) {
+            TypeVariable<?>[] interfaceTypeVars = interfaceClass.getTypeParameters();
+            int indexInInterface = getIndexSafe(interfaceTypeVars, typeVariable);
+
+            if (indexInInterface != -1) {
+              Type[] interfaceActualTypes = paramInterfaceType.getActualTypeArguments();
+              if (indexInInterface < interfaceActualTypes.length) {
+                return interfaceActualTypes[indexInInterface];
+              }
+            }
+          }
+        }
+      }
+
+      currentClass = currentClass.getSuperclass();
+    }
+
+    return null; // Not found
+  }
