+
     static class UsingObjenesis implements ClassInstantiator {
 
         private final Objenesis objenesis;
@@ -21,5 +23,56 @@ interface ClassInstantiator {
         public <T> T instantiate(Class<T> type) {
             return objenesis.newInstance(type);
         }
+
+        public <T> T instantiate(Class<T> type, Object outerInstance) {
+            // Get the constructor that takes the outer instance as the first parameter
+            java.lang.reflect.Constructor<T> constructor;
+            try {
+                // For the generated mock class, we need to find the constructor signature that takes
+                // the outer class instance as the first parameter
+                for (java.lang.reflect.Constructor<?> cons : type.getDeclaredConstructors()) {
+                    Class<?>[] paramTypes = cons.getParameterTypes();
+                    if (paramTypes.length > 0 && paramTypes[0] != null &&
+                        outerInstance != null && paramTypes[0].isAssignableFrom(outerInstance.getClass())) {
+                        // Found a constructor with the right outer instance parameter
+                        @SuppressWarnings("unchecked")
+                        java.lang.reflect.Constructor<T> typedCons = (java.lang.reflect.Constructor<T>) cons;
+
+                        if (!typedCons.isAccessible()) {
+                            typedCons.setAccessible(true);
+                        }
+
+                        Object[] args = new Object[paramTypes.length];
+                        args[0] = outerInstance;
+                        // Initialize other parameters to null/default values
+                        for (int i = 1; i < args.length; i++) {
+                            args[i] = getDefaultValue(paramTypes[i]);
+                        }
+
+                        return typedCons.newInstance(args);
+                    }
+                }
+
+                // If no constructor matches, fall back to default instantiation
+                return objenesis.newInstance(type);
+            } catch (Exception e) {
+                // Fall back to default instantiation if constructor approach fails
+                return objenesis.newInstance(type);
+            }
+        }
+
+        // Helper method to get default value for primitive types
+        private Object getDefaultValue(Class<?> type) {
+            if (type == boolean.class) return false;
+            if (type == byte.class) return (byte) 0;
+            if (type == char.class) return '\0';
+            if (type == short.class) return (short) 0;
+            if (type == int.class) return 0;
+            if (type == long.class) return 0L;
+            if (type == float.class) return 0.0f;
+            if (type == double.class) return 0.0;
+            // For object types, return null
+            return null;
+        }
     }
 }
