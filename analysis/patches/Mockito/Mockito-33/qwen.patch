+
+        /* Avoid unnecessary cloning */
+        // Compare methods more robustly to handle generic inheritance in interfaces
+        // Check method name, parameter types and return type equality
+        if (!m1.getName().equals(m2.getName()) ||
+            !java.util.Arrays.equals(m1.getParameterTypes(), m2.getParameterTypes())) {
+            return false;
+        }
+
+        // Handle return type comparison for generics properly
+        // For the InheritedGenericsPolimorphicCallTest case, both methods should have the same signature
+        // even when called on different interface views (MyIterable and Iterable)
+        return m1.getReturnType().equals(m2.getReturnType()) ||
+               m1.getReturnType().isAssignableFrom(m2.getReturnType()) ||
+               m2.getReturnType().isAssignableFrom(m1.getReturnType());
     }
     
