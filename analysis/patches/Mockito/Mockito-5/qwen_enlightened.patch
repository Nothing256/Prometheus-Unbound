+    /**
+     * Checks if the exception is an ArgumentsAreDifferent exception using reflection
+     * to avoid hard dependency on JUnit classes which might not be present.
+     */
+    private boolean isArgumentsAreDifferentException(Throwable e) {
+        try {
+            // Use reflection to check if the exception is of the JUnit specific type
+            Class<?> argumentsAreDifferentClass = Class.forName("org.mockito.exceptions.verification.junit.ArgumentsAreDifferent");
+            return argumentsAreDifferentClass.isInstance(e);
+        } catch (ClassNotFoundException classNotFound) {
+            // If the class is not found, it means JUnit is not on the classpath
+            // In this case, the exception can't be of that type
+            return false;
+        }
+    }
