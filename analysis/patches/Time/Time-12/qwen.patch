diff --git a/src/main/java/org/joda/time/LocalDate.java b/src/main/java/org/joda/time/LocalDate.java
index 38685311..70f9ae32 100644
--- a/src/main/java/org/joda/time/LocalDate.java
+++ b/src/main/java/org/joda/time/LocalDate.java
@@ -207,9 +207,13 @@ public final class LocalDate
         if (calendar == null) {
             throw new IllegalArgumentException("The calendar must not be null");
         }
-        int yearOfEra = calendar.get(Calendar.YEAR);
+        int year = calendar.get(Calendar.YEAR);
+        if (calendar.get(Calendar.ERA) == GregorianCalendar.BC) {
+            // For BC years, convert properly for ISO chronology (no year 0)
+            year = 1 - year;  // 1 BC (year 1) -> 0, 2 BC (year 2) -> -1, 3 BC (year 3) -> -2
+        }
         return new LocalDate(
-            yearOfEra,
+            year,
             calendar.get(Calendar.MONTH) + 1,
             calendar.get(Calendar.DAY_OF_MONTH)
         );
@@ -240,9 +244,16 @@ public final class LocalDate
         if (date == null) {
             throw new IllegalArgumentException("The date must not be null");
         }
-            // handle years in era BC
+        // Create a calendar to check for BC era and handle year conversion properly
+        GregorianCalendar cal = new GregorianCalendar();
+        cal.setTime(date);
+        int year = cal.get(Calendar.YEAR);
+        if (cal.get(Calendar.ERA) == GregorianCalendar.BC) {
+            // For BC years, convert properly for ISO chronology (no year 0)
+            year = 1 - year;  // 1 BC (year 1) -> 0, 2 BC (year 2) -> -1, 3 BC (year 3) -> -2
+        }
         return new LocalDate(
-            date.getYear() + 1900,
+            year,
             date.getMonth() + 1,
             date.getDate()
         );
