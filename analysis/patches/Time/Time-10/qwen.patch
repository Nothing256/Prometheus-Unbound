+    private static long setMonthDayWithYear(int year, ReadablePartial monthDay, Chronology chrono) {
+        // Create a date with the specified year + month + day
+        int month = monthDay.getValue(0);  // monthOfYear
+        int day = monthDay.getValue(1);    // dayOfMonth
+        return chrono.getDateTimeMillis(year, month, day, 0, 0, 0, 0);
