+    /**
+     * Special serializer for BigDecimal when both @JsonFormat(shape=STRING) and
+     * WRITE_BIGDECIMAL_AS_PLAIN are active.
+     */
+    private static class BigDecimalAsStringPlainSerializer extends StdScalarSerializer<Number> {
+        private static final long serialVersionUID = 1L;
+        protected final NumberSerializer parent;
+
+        public BigDecimalAsStringPlainSerializer(NumberSerializer parent) {
+            super(BigDecimal.class, false);
+            this.parent = parent;
+        }
+
+        @Override
+        public void serialize(Number value, JsonGenerator gen, SerializerProvider provider) throws IOException {
+            if (value instanceof BigDecimal) {
+                // Serialize as plain string when WRITE_BIGDECIMAL_AS_PLAIN is enabled
+                gen.writeString(((BigDecimal) value).toPlainString());
+            } else {
+                // Fallback for other number types
+                gen.writeString(value.toString());
+            }
+        }
+    }
+
+    private boolean isBigDecimalType(BeanProperty property) {
+        if (property != null) {
+            return property.getType().getRawClass() == BigDecimal.class;
+        }
+        // If property is null, we can't determine the exact type, so conservatively check handled type
+        // For NumberSerializer, this should only be called for Number types
+        Class<?> handledClass = handledType();
+        return handledClass == BigDecimal.class;
+    }
