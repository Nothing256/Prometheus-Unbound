-        return new CreatorProperty(this, deser, _nullProvider);
+        // If the null provider is the same as the value deserializer (the default case)
+        // or if it's the MISSING_VALUE_DESERIALIZER (another default case),
+        // then we should update the null provider to match the new deserializer
+        NullValueProvider nullProviderToUse = _nullProvider;
