+    @Override
+    public Object deserializeTypedFromScalar(JsonParser p, DeserializationContext ctxt) throws IOException {
+        // First, check for the specific case: empty string with ACCEPT_EMPTY_STRING_AS_NULL_OBJECT enabled
+        if (p.getCurrentToken() == JsonToken.VALUE_STRING) {
+            String str = p.getText();
+            if (str != null && str.isEmpty() && ctxt.isEnabled(DeserializationFeature.ACCEPT_EMPTY_STRING_AS_NULL_OBJECT)) {
+                return null;
+            }
+        }
+
+        // For other cases, delegate to the default implementation handling
+        return _deserializeTypedUsingDefaultImpl(p, ctxt, null);
+    }
