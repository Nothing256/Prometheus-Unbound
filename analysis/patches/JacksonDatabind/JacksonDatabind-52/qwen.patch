+
+        /**
+         * @since 2.8
+         */
+        public ExternalTypeHandler build(SettableBeanProperty[] creatorProperties) {
+            ExtTypedProperty[] props = _properties.toArray(new ExtTypedProperty[_properties.size()]);
+
+            // [databind#999]: If we have creator properties, need to link possible
+            // type id properties that are also creator properties
+            if (creatorProperties != null) {
+                for (SettableBeanProperty creatorProp : creatorProperties) {
+                    Integer propIndex = _nameToPropertyIndex.get(creatorProp.getName());
+                    if (propIndex != null) {
+                        ExtTypedProperty extProp = props[propIndex];
+                        // Check if the current property is the type property for this external type
+                        if (extProp.hasTypePropertyName(creatorProp.getName())) {
+                            extProp.linkTypeProperty(creatorProp);
+                        }
+                    }
+                }
+            }
+
+            return new ExternalTypeHandler(props, _nameToPropertyIndex, null, null);
+        }
     }
 
