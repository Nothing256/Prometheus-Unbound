+    /**
+     * Safe version of pad4 that can handle positive years without
+     * the risk of passing negative values to the original pad2/pad4 functions
+     */
+    private static void safePad4(StringBuffer buffer, int value) {
+        // This method is only called with positive values (absolute values of negative years)
+        // so we can safely use the original logic without worrying about negative handling
+        int h = value / 100;
+        if (h == 0) {
+            buffer.append('0').append('0');
+        } else {
+            safePad2(buffer, h);
+            value -= (100 * h);
+        }
+        safePad2(buffer, value);
+    }
+
+    /**
+     * Safe version of pad2 that can handle positive values without
+     * the risk of creating invalid characters for negative values
+     */
+    private static void safePad2(StringBuffer buffer, int value) {
+        // This method is only called with positive values, so original logic is safe
+        int tens = value / 10;
+        if (tens == 0) {
+            buffer.append('0');
+        } else {
+            buffer.append((char) ('0' + tens));
+            value -= 10 * tens;
+        }
+        buffer.append((char) ('0' + value));
+    }
