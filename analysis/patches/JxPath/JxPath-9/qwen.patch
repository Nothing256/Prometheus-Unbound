     public Object computeValue(org.apache.commons.jxpath.ri.EvalContext context) {
+        // Check for NaN before doing comparison - if either side is NaN,
+        // no comparison returns true
+        Object l = args[0].compute(context);
+        Object r = args[1].compute(context);
+
+        // Handle NaN: if either is NaN, comparison returns false
+        if (l instanceof Number || r instanceof Number) {
+            double ld = org.apache.commons.jxpath.ri.InfoSetUtil.doubleValue(l);
+            double rd = org.apache.commons.jxpath.ri.InfoSetUtil.doubleValue(r);
+            if (Double.isNaN(ld) || Double.isNaN(rd)) {
+                return Boolean.FALSE;
+            }
+        }
+
         return equal(context, args[0], args[1]) ? Boolean.TRUE : Boolean.FALSE;
     }
