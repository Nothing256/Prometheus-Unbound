+    private boolean shouldPreserveSpace(Node node) {
+        // Determine the starting point for checking xml:space attribute
+        // For text nodes, check parent elements (since text nodes don't have attributes)
+        // For element nodes, check the element itself first, then its ancestors
+        Node current;
+
+        if (node.getNodeType() == Node.ELEMENT_NODE) {
+            // Start with the element itself
+            current = node;
+        } else {
+            // For text nodes, CDATA sections, etc., start with the parent element
+            current = node.getParentNode();
+        }
+
+        // Traverse up the parent chain to find xml:space attribute
+        while (current != null) {
+            if (current.getNodeType() == Node.ELEMENT_NODE) {
+                Element elem = (Element) current;
+                // Check for xml:space attribute using namespace-aware access
+                String spaceAttr = elem.getAttributeNS(XML_NAMESPACE_URI, "space");
+                if (spaceAttr == null || spaceAttr.equals("")) {
+                    // Fallback to non-namespace aware access in case
+                    spaceAttr = elem.getAttribute("xml:space");
+                }
+
+                if (spaceAttr != null && spaceAttr.equals("preserve")) {
+                    return true;
+                } else if (spaceAttr != null && spaceAttr.equals("default")) {
+                    // Found xml:space="default", so don't preserve space
+                    return false;
+                }
+            }
+            current = current.getParentNode();
+        }
+        // Default behavior is to not preserve space (for backward compatibility)
+        return false;
+    }
