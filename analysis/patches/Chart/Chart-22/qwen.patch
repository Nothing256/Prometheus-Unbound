+                KeyedObjects dataRow = (KeyedObjects) this.rows.get(r);
+                // Check if the object exists in this row for the specified column key
+                int objectIndex = dataRow.getIndex(columnKey);
+                if (objectIndex >= 0 && dataRow.getObject(objectIndex) != null) {
+                    columnAllNull = false;
+                    break;
+                }
+            }
+
+            if (columnAllNull) {
+                this.columnKeys.remove(colIndex);
+            }
+        }
     }
 
