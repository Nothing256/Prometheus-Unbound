      */
+    public int removeDups(ParseSettings settings) {
+        int initialSize = size;
+
+        // Create a new set of attributes without duplicates
+        Attributes newAttrs = new Attributes();
+        for (int i = 0; i < size; i++) {
+            String key = keys[i];
+            String value = vals[i];
+
+            boolean isDuplicate = false;
+            // Check if this key already exists in newAttrs
+            for (int j = 0; j < newAttrs.size; j++) {
+                if (settings.preserveAttributeCase()) {
+                    // Only exact case matches are duplicates
+                    if (key.equals(newAttrs.keys[j])) {
+                        isDuplicate = true;
+                        break;
+                    }
+                } else {
+                    // Case-insensitive matches are duplicates
+                    if (key.equalsIgnoreCase(newAttrs.keys[j])) {
+                        isDuplicate = true;
+                        break;
+                    }
+                }
+            }
+
+            if (!isDuplicate) {
+                newAttrs.add(key, value);
+            }
+        }
+
+        // Copy the new attributes back to this instance
+        this.size = newAttrs.size;
+        this.keys = newAttrs.keys;
+        this.vals = newAttrs.vals;
+
+        return initialSize - size; // Return number of removed duplicates
+    }
 
