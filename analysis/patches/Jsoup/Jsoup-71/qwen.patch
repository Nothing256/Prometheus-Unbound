+package org.jsoup.nodes;
+
+import org.jsoup.helper.Validate;
+import org.jsoup.parser.ParseSettings;
+import org.jsoup.parser.Tag;
+
+/**
+ * A PseudoTextElement is a fake {@link Element} that wraps text nodes, so that text nodes can be selected using
+ * the normal element selectors.
+ */
+public class PseudoTextElement extends Element {
+    private String text;
+
+    /**
+     * Create a new PseudoTextElement.
+     * @param tag the tag for this pseudo element
+     * @param baseUri the base URI
+     * @param text the text to wrap
+     */
+    public PseudoTextElement(Tag tag, String baseUri, String text) {
+        super(tag, baseUri);
+        this.text = text;
+    }
+
+    /**
+     * Create a new PseudoTextElement with a special tag.
+     * @param text the text to wrap
+     */
+    public PseudoTextElement(String text) {
+        this(Tag.valueOf("#text"), "", text);
+    }
+
+    @Override
+    public String text() {
+        return text;
+    }
+
+    @Override
+    public String ownText() {
+        return text;
+    }
+
+    @Override
+    public Element text(String newText) {
+        Validate.notNull(newText);
+        this.text = newText;
+        return this;
+    }
+
+    @Override
+    public String nodeName() {
+        return "#text";
+    }
+
+    @Override
+    public String toString() {
+        return text;
+    }
+
+    @Override
+    public String html() {
+        return org.jsoup.helper.StringUtil.normaliseWhitespace(text);
+    }
+}
