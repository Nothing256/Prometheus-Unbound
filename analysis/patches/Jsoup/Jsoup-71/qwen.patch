     }
+    
+    /**
+     * Evaluator for matching text nodes as elements using :matchText pseudo selector
+     */
+    public static final class MatchText extends Evaluator {
+        @Override
+        public boolean matches(Element root, Element element) {
+            return element instanceof org.jsoup.nodes.PseudoTextElement;
+        }
+
+        @Override
+        public String toString() {
+            return ":matchText";
+        }
+    }
