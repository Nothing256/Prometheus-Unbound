@@ -145,7 +145,8 @@ enum TokeniserState {
                     t.advanceTransition(EndTagOpen);
                     break;
                 case '?':
-                    t.advanceTransition(BogusComment);
+                    t.createXmlDeclarationPending(false); // false for xml declaration (processing instructions have different format)
+                    t.advanceTransition(XmlDeclaration);
                     break;
                 default:
                     if (r.matchesLetter()) {
@@ -1789,8 +1790,28 @@ enum TokeniserState {
             r.matchConsume("]]>");
             t.transition(Data);
         }
-    };
+    },
+    XmlDeclaration {
+        void read(Tokeniser t, CharacterReader r) {
+            // Read everything between <? and ?>, or handle malformed case
+            String data = r.consumeTo("?>");
 
+            // Check if we found the closing ?>
+            if (r.matchConsume("?>")) {
+                // Found proper closing
+                // For XML declarations (isProcessingInstruction = false), we need to include the ? before > in the data
+                // according to XmlDeclaration comment: "and last data char should be ?"
+                t.xmlDeclarationPending.data.append(data).append('?');
+                t.emit(t.xmlDeclarationPending);
+                t.transition(Data);
+            } else {
+                // Hit EOF without finding ?>, emit what we have with error
+                t.xmlDeclarationPending.data.append(data);
+                t.emit(t.xmlDeclarationPending);
+                t.transition(Data);
+            }
+        }
+    };
 
     abstract void read(Tokeniser t, CharacterReader r);
 
