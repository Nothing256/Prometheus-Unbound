@@ -207,6 +207,31 @@ abstract class Token {
         }
     }
 
+    static class XmlDeclaration extends Token {
+        final StringBuilder data = new StringBuilder();
+        final boolean isProcessingInstruction; // <? = true, <! = false
+
+        XmlDeclaration(boolean isProcessingInstruction) {
+            type = TokenType.XmlDeclaration;
+            this.isProcessingInstruction = isProcessingInstruction;
+        }
+
+        String getData() {
+            return data.toString();
+        }
+
+        boolean isProcessingInstruction() {
+            return isProcessingInstruction;
+        }
+
+        @Override
+        public String toString() {
+            return isProcessingInstruction ?
+                "<?" + getData() + "?>" :
+                "<!" + getData() + ">";
+        }
+    }
