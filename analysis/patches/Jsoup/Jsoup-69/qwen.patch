+    /**
+     * Remove this element from any form it may be associated with.
+     */
+    protected void removeFromAnyForm() {
+        // Walk up the tree to find if this element is contained within a form element
+        Element parent = this.parent();
+        while (parent != null) {
+            if (parent instanceof FormElement) {
+                FormElement form = (FormElement) parent;
+                form.removeElement(this);
+                break; // Only remove from one form
+            }
+            parent = parent.parent();
+        }
+    }
